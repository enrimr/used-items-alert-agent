# =============================================
# WALLAPOP AGENT - CONFIGURACIÓN
# =============================================
# Copia este archivo a .env y configura los valores

# --- BÚSQUEDA ---
# Palabras clave para buscar (requerido)
KEYWORDS=iphone 13

# Precio mínimo en euros (opcional, dejar vacío para sin límite)
MIN_PRICE=100

# Precio máximo en euros (opcional, dejar vacío para sin límite)
MAX_PRICE=500

# Categoría (opcional). Valores posibles:
# 12465 = Tecnología
# 12579 = Móviles y telefonía
# 15000 = Informática
# 12545 = Moda y accesorios
# 12543 = Motor
# 12463 = Deporte y ocio
# 12459 = Hogar y jardín
# 12467 = Televisión y audio
# 12461 = Consolas y videojuegos
# 12473 = Cámaras y fotografía
# 14000 = Coleccionismo
# 12449 = Libros y música
# 12469 = Bebés y niños
# 12471 = Otros
# Dejar vacío para buscar en todas las categorías
CATEGORY_ID=

# --- AGENTE ---
# Intervalo de comprobación en segundos (mínimo recomendado: 60)
POLL_INTERVAL_SECONDS=90

# Número máximo de resultados por búsqueda
MAX_RESULTS=40

# Modo headless del navegador (true=sin ventana, false=con ventana)
HEADLESS=true

# --- NOTIFICACIONES (opcional) ---
# Notificaciones de escritorio (true/false)
DESKTOP_NOTIFICATIONS=true

# Guardar resultados en archivo JSON
SAVE_TO_FILE=true
OUTPUT_FILE=./encontrados.json

# --- EMAIL (opcional) ---
# Dirección de email donde recibir las alertas
EMAIL_TO=tuemail@gmail.com

# Dirección remitente (normalmente igual que EMAIL_SMTP_USER)
EMAIL_FROM=tuemail@gmail.com

# Configuración SMTP
# Gmail: smtp.gmail.com, puerto 587, SECURE=false
# Outlook/Hotmail: smtp.office365.com, puerto 587, SECURE=false
# Yahoo: smtp.mail.yahoo.com, puerto 587, SECURE=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=tuemail@gmail.com
# Para Gmail: crea una "Contraseña de aplicación" en https://myaccount.google.com/apppasswords
EMAIL_SMTP_PASS=tucontraseñadeaplicacion

# --- WEB SERVER ---
# Puerto del servidor web (Railway sobreescribe esto con PORT automáticamente)
WEB_PORT=3000

# URL base pública (importante para los enlaces de cancelación en los emails)
# En local:    http://localhost:3000
# En Railway:  https://tuapp.up.railway.app
BASE_URL=http://localhost:3000

# Intervalo del worker en segundos (cada cuánto busca para todos los suscritos)
WORKER_INTERVAL_SECONDS=120

# --- RAILWAY (solo necesario en producción) ---
# Ruta al SQLite - en Railway monta un volumen en /data y pon: /data/alerts.db
# DB_PATH=/data/alerts.db

# Chromium en Railway - se configura automáticamente con Dockerfile
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# --- ADMIN ---
# Contraseña para acceder al panel /admin (dejar vacío para deshabilitar)
# Acceso: https://tudominio.com/admin (usuario: admin, contraseña: lo que pongas aquí)
ADMIN_PASSWORD=tucontraseñaadmin
