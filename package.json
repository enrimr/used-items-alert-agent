{
  "name": "wallapop-alert-agent",
  "version": "1.0.0",
  "description": "Node.js agent that monitors Wallapop Spain for new listings, filters by keywords/price/category, excludes reserved items, and sends email alerts.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "once": "node index.js --once",
    "help": "node index.js --help",
    "web": "node server.js",
    "web:only": "node server.js --web",
    "test": "NODE_ENV=test node_modules/.bin/jest --runInBand --forceExit",
    "test:watch": "NODE_ENV=test node_modules/.bin/jest --watch",
    "test:coverage": "NODE_ENV=test node_modules/.bin/jest --runInBand --forceExit --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testEnvironmentOptions": {
      "env": { "NODE_ENV": "test" }
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 10000,
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "src/scraper.js",
      "src/agent.js",
      "src/notifier.js",
      "src/store.js",
      "server.js",
      "index.js"
    ]
  },
  "keywords": [
    "wallapop",
    "scraper",
    "agent",
    "monitor",
    "alerts",
    "email"
  ],
  "author": "Enrique Mendoza Robaina",
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "homepage": "https://github.com/enrimr/wallapop-alert-agent",
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^9.6.0",
    "chalk": "^4.1.2",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "node-notifier": "^10.0.1",
    "nodemailer": "^8.0.1",
    "puppeteer": "^19.11.1",
    "resend": "^6.9.2",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-circus": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "supertest": "^7.2.2"
  }
}
